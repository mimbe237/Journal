DATABASE_URL="postgresql://user:password@localhost:5432/journal?schema=public"
JWT_SECRET="replace-with-strong-secret"

# Email Configuration (Resend)
# Obtenez votre clé sur https://resend.com/api-keys
RESEND_API_KEY="re_123456789"
EMAIL_FROM="Journal <ne-pas-repondre@votre-domaine.com>"

# URL de l'application (pour les liens dans les emails)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stockage (Optionnel, par défaut dans ./storage)
# PRIVATE_STORAGE_ROOT="/var/www/journal/storage"

# Configuration S3 (Pour la production / Vercel)
# STORAGE_PROVIDER="s3"
# S3_ACCESS_KEY_ID="votre-access-key"
# S3_SECRET_ACCESS_KEY="votre-secret-key"
# S3_REGION="eu-west-3"
# S3_BUCKET_NAME="journal-storage"
# S3_ENDPOINT="https://..." # Optionnel (pour Cloudflare R2, MinIO, etc.)

# OpenAI API (Pour l'extraction automatique des titres et tags)
# Obtenez votre clé sur https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."
